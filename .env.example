# ─── Udarsy Backend — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
BACKEND_URL=http://localhost:5000

# Internal API key shared with the frontend (generate with: openssl rand -hex 32)
APP_API_KEY=your-random-hex-api-key

# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/udarsy
# Or Atlas: mongodb+srv://user:pass@cluster.mongodb.net/udarsy

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=your-jwt-secret-min-64-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-64-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── Cookies ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
COOKIE_SECRET=your-cookie-secret-min-32-chars
COOKIE_MAX_AGE=604800000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
FRONTEND_URL=http://localhost:3000,http://localhost:5173

# ── File Uploads ──────────────────────────────────────────────────────────────
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# ── Cloudflare R2 (file storage) ──────────────────────────────────────────────
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=your-bucket-name
R2_PUBLIC_DOMAIN=pub-xxxx.r2.dev

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ── AI / Image Generation ─────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
# Infip keys: comma-separated (alternative to keys.json which must not be committed)
INFIP_API_KEYS=infip-xxxx,infip-yyyy

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="Udarsy" <noreply@udarsy.com>
ADMIN_EMAIL=admin@udarsy.com

# ── Resend (transactional email) ──────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Google Analytics (server-side Measurement Protocol) ───────────────────────
GA_MEASUREMENT_ID=G-XXXXXXXXXX
GA_API_SECRET=your-ga-api-secret
